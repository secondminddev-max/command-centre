# SecondMind AI Platform — Environment Configuration
# Copy this file to .env and fill in your real keys
# The server will auto-load .env on startup if present

# ── Stripe Payments ────────────────────────────────────────────────────────────
# Required for POST /api/pay checkout sessions (StripePay agent)
STRIPE_SECRET_KEY=sk_live_YOUR_KEY_HERE

# Optional: Stripe webhook signing secret (WebhookAgent uses this to verify events)
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE

# ── Bluesky Social ──────────────────────────────────────────────────────────────
# Required for BlueSky agent to post
BSKY_HANDLE=yourhandle.bsky.social
BSKY_PASSWORD=YOUR_APP_PASSWORD

# ── Telegram Bot ───────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN
TELEGRAM_CHAT_ID=YOUR_CHAT_ID

# ── Email (SendGrid) ───────────────────────────────────────────────────────────
SENDGRID_API_KEY=SG.YOUR_KEY_HERE
EMAIL_FROM=noreply@secondmind.ai
