# SecondMind AI Platform — Environment Configuration
# Copy this file to .env and fill in your real keys
# The server will auto-load .env on startup if present

# ── HQ API Key ───────────────────────────────────────────────────────────────
# Protects admin endpoints (/api/agent/spawn, /api/ceo/delegate, etc.)
# If not set, a random key is generated at startup and printed to console
HQ_API_KEY=

# ── Anthropic (Claude AI) ───────────────────────────────────────────────────
# Required for CEO agent and all Claude-powered operations
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# ── Stripe Payments ─────────────────────────────────────────────────────────
# Required for POST /api/pay checkout sessions and webhook processing
# Get keys at https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_YOUR_KEY_HERE
STRIPE_PUBLISHABLE_KEY=pk_live_YOUR_KEY_HERE

# Stripe webhook signing secret (for signature verification)
# Get from https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE

# Optional: static payment link fallback if no secret key
# STRIPE_PAYMENT_LINK=https://buy.stripe.com/YOUR_LINK

# ── Gmail / Email ───────────────────────────────────────────────────────────
# Required for sending emails via Gmail OAuth2
# Set up OAuth2 credentials at https://console.cloud.google.com
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_USER=you@gmail.com

# Optional: override sender/recipient addresses
# EMAIL_FROM=noreply@secondmind.ai
# EMAIL_TO=hello@secondmindlabs.com

# ── Telegram Bot ────────────────────────────────────────────────────────────
# Required for Telegram notifications
# Create a bot at https://t.me/BotFather
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN
TELEGRAM_CHAT_ID=YOUR_CHAT_ID

# ── Bluesky Social ──────────────────────────────────────────────────────────
# Required for Bluesky agent to post
# Use an app password from https://bsky.app/settings/app-passwords
BSKY_HANDLE=yourhandle.bsky.social
BSKY_PASSWORD=YOUR_APP_PASSWORD

# ── Public URL ──────────────────────────────────────────────────────────────
# Set if running behind a tunnel/proxy (Cloudflare, ngrok, etc.)
# Used for Stripe success/cancel redirect URLs
# PUBLIC_BASE_URL=https://yourdomain.com

# ── Delegation Token ────────────────────────────────────────────────────────
# Internal token for chain-of-command delegation between agents
# Auto-generated if not set
# DELEGATION_TOKEN=

# ── Render Hosting ──────────────────────────────────────────────────────────
# Set automatically by Render.com — starts system in paused/build mode
# RENDER=true
