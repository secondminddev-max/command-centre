# ═══════════════════════════════════════════════════════════════════════
# Command Centre (HQ) — Environment Configuration
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════════════

# ── Claude API (Required) ──────────────────────────────────────────────
# The CEO agent uses Claude Code CLI. Install: npm install -g @anthropic-ai/claude-code
# Then authenticate: claude login
# No API key needed here — Claude Code handles auth via CLI.

# ── Gmail / Email (Optional — enables email agent) ─────────────────────
# Create OAuth2 credentials at https://console.cloud.google.com/apis/credentials
# Select "Desktop app" type, download client ID and secret
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_USER=your-email@gmail.com

# ── Bluesky Social (Optional — enables social posting) ─────────────────
BLUESKY_HANDLE=your-handle.bsky.social
BLUESKY_APP_PASSWORD=

# ── Stripe Payments (Optional — enables revenue/checkout) ──────────────
# Get keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# ── Telegram Bot (Optional — enables Telegram notifications) ───────────
# Create a bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Server Config ─────────────────────────────────────────────────────
PORT=5050
